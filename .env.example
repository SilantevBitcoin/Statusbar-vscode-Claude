# Токены для публикации расширения. Скопируй в .env и впиши значения (.env в .gitignore).
# ВАЖНО: вписывай токены в .env, НЕ сюда — этот файл трекается git.

# VS Code Marketplace — Azure DevOps Personal Access Token.
# Где взять: dev.azure.com → User settings → Personal Access Tokens → New Token
#   Organization: All accessible organizations | Scopes: Marketplace > Manage
VSCE_PAT=

# Open VSX — Access Token.
# Где взять: open-vsx.org (вход через GitHub) → Settings → Access Tokens → Generate New Token
# (перед этим один раз: войти через Eclipse и подписать Publisher Agreement)
OVSX_PAT=
